<?php $element = $this->getData('element'); ?>

<span class="multiselectPay">
    <input type="hidden"
           id="<?= $block->escapeHtmlAttr($element->getHtmlId()) ?>"
           name="<?= $block->escapeHtmlAttr($element->getName()) ?>"
           value="<?= $block->escapeHtmlAttr($element->getValue()) ?>" />

    <span class="ms_options">
        <?php
        $selectedValues = explode(',', (string)($element->getValue() ?? ''));

        foreach ($element->getValues() as $value):
            if (empty($value) || empty($value['value'])):
                continue;
            endif;

            if (is_array($value['value'])):
                ?>
                <span class="ms_optgroup">
                    <span class="ms_optgroup_label"><?= $block->escapeHtml($value['label']) ?></span>

                    <?php foreach ($value['value'] as $multiValue):
                        $isSelected = in_array($multiValue['value'], $selectedValues, true);
                        ?>
                        <span class="ms_option <?= $isSelected ? 'selected' : '' ?>"
                              data-value="<?= $block->escapeHtmlAttr($multiValue['value']) ?>">
                            <?= $block->escapeHtml($multiValue['label']) ?>
                        </span>
                    <?php endforeach; ?>
                </span>
            <?php else:
                $isSelected = in_array($value['value'], $selectedValues, true);
                ?>
                <span class="ms_option <?= $isSelected ? 'selected' : '' ?>"
                      data-value="<?= $block->escapeHtmlAttr($value['value']) ?>">
                    <?= $block->escapeHtml($value['label']) ?>
                </span>
            <?php endif; ?>
        <?php endforeach; ?>
    </span>
</span>

<script type="text/x-magento-init">
    {
        "*": {
            "Paynl_Payment/js/multiselect": {
                "element": "<?= $block->escapeJs($element->getHtmlId()) ?>"
        }
    }
}
</script>